{
  "name": "promptario-app",
  "version": "1.2.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build:preview": "eas build -p android --profile preview",
    "build:production": "eas build -p android --profile production"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-clipboard": "~7.0.0",
    "expo-font": "~13.0.0",
    "expo-status-bar": "~1.13.0",
    "react": "18.3.1",
    "react-native": "0.76.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "prettier": "^3.2.0",
    "typescript": "~5.3.3"
  },
  "private": true
}
