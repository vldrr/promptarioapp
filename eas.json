{
  "cli": { "version": ">= 5.0.0" },
  "build": {
    "preview": {
      "android": { 
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "distribution": "internal"
    },
    "production": {
      "android": { 
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccount": "./service-account-key.json",
        "track": "internal"
      }
    }
  }
}
